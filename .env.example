# === Database (PostgreSQL) ===
POSTGRES_USER=icfr_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=icfr_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://icfr_user:changeme_in_production@postgres:5432/icfr_db

# === MinIO (S3 호환 파일 저장소) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_in_production
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=icfr-evidence
MINIO_USE_SSL=false

# === JWT 인증 ===
# 운영 시 반드시 안전한 랜덤 문자열로 교체 (32바이트 이상 권장)
JWT_SECRET_KEY=please_generate_a_strong_random_key_for_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# === Application ===
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=ICFR System
APP_VERSION=0.1.0

# === CORS (Phase 1 추가 예정) ===
# CORS_ALLOWED_ORIGINS=http://localhost:5173
